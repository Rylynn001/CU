# 环境变量 / 密钥
.env
**/.env

# 日志
*.log

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# 模型文件（忽略内容，保留目录结构）
models/**
!models/**/
!models/**/.gitkeep
# configs 目录保留 yaml 配置文件
!models/configs/*.yaml

# 运行时目录（忽略内容，保留目录结构）
output/**
!output/.gitkeep
input/**
!input/.gitkeep
!input/3d/
!input/3d/.gitkeep
temp/**
!temp/.gitkeep

# 用户数据
user/

# IDE
.idea/
.vscode/

# 系统文件
.DS_Store
Thumbs.db
